{
  "name": "clearpath",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "format": "prettier --write app frontend *.json *.mjs *.ts *.md docs/**/*.md",
    "format:check": "prettier --check app frontend *.json *.mjs *.ts *.md docs/**/*.md"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "leaflet": "^1.9.4",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
