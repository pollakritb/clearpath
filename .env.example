# ───────────────────────────────────────────────────────────
# ClearPath — environment variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (อย่า commit .env.local)
# ───────────────────────────────────────────────────────────

# ── External APIs ──────────────────────────────────────────
# OpenRouteService — https://openrouteservice.org/dev (ฟรี 2,000 req/วัน)
ORS_API_KEY=

# OpenWeatherMap — https://openweathermap.org/api (ฟรี 1,000 calls/วัน)
OPENWEATHER_API_KEY=

# NASA FIRMS — https://firms.modaps.eosdis.nasa.gov/api/ (สมัครรอ 1-2 วัน)
FIRMS_MAP_KEY=

# air4thai ไม่ต้องใช้ key (เปลี่ยน endpoint ได้ถ้าจำเป็น)
AIR4THAI_URL=http://air4thai.pcd.go.th/services/getNewAQI_JSON.php

# ── Supabase ───────────────────────────────────────────────
# ใช้ service_role key ฝั่ง server เท่านั้น (มีสิทธิ์เขียน) — ห้ามใส่ฝั่ง browser
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron ───────────────────────────────────────────────────
# secret สำหรับยืนยันว่า /api/cron/sync ถูกเรียกจาก Vercel Cron จริง
CRON_SECRET=

# ── Dev only ───────────────────────────────────────────────
# origin ของ FastAPI ตอน dev (Next จะ proxy ไปที่นี่)
BACKEND_ORIGIN=http://127.0.0.1:8000
