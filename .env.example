# ───────────────────────────────────────────────────────────
# ClearPath — environment variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (อย่า commit .env.local)
# ───────────────────────────────────────────────────────────

# ── External APIs ──────────────────────────────────────────
# OpenWeatherMap — https://openweathermap.org/api (ฟรี 1,000 calls/วัน)
OPENWEATHER_API_KEY=

# NASA FIRMS — https://firms.modaps.eosdis.nasa.gov/api/ (สมัครรอ 1-2 วัน)
FIRMS_MAP_KEY=

# air4thai ไม่ต้องใช้ key (เปลี่ยน endpoint ได้ถ้าจำเป็น)
AIR4THAI_URL=http://air4thai.pcd.go.th/services/getNewAQI_JSON.php

# OpenAI Responses API — OCR ภาพหน้าจอเครื่องวัด PM2.5
# ถ้าไม่ตั้งค่า ระบบยังรับภาพได้ตามปกติ และ Admin จะอ่าน/กรอกค่าจากภาพด้วยตนเอง
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-5.4-mini

# ── Supabase ───────────────────────────────────────────────
# ใช้ service_role key ฝั่ง server เท่านั้น (มีสิทธิ์เขียน) — ห้ามใส่ฝั่ง browser
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REPORT_IMAGE_BUCKET=report-images

# ค่า public สำหรับ Supabase Email OTP ใน Next.js (anon key ไม่ใช่ service role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ลงนาม camera session อายุ 5 นาที (ใช้ random secret ยาวอย่างน้อย 32 ตัวอักษร)
CAPTURE_SESSION_SECRET=
CAPTURE_SESSION_TTL_SECONDS=300

# ── Cron ───────────────────────────────────────────────────
# secret สำหรับยืนยันว่า /api/cron/sync ถูกเรียกจาก Vercel Cron จริง
CRON_SECRET=

# ── Web Push ──────────────────────────────────────────────
# สร้าง VAPID key pair แล้วเก็บ private key ฝั่ง server เท่านั้น
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# เปิดได้เมื่อ artifact ใน backend/model_artifacts ผ่าน activation gate เท่านั้น
ML_FORECAST_ENABLED=false

# ── Dev only ───────────────────────────────────────────────
# origin ของ FastAPI ตอน dev (Next จะ proxy ไปที่นี่)
BACKEND_ORIGIN=http://127.0.0.1:8000

# ใช้เฉพาะตอนพัฒนาเมื่อยังไม่มี Supabase: in-memory data หายเมื่อปิด Backend
LOCAL_DEMO_MODE=false
