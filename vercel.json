{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/**",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/index" }],
  "crons": [
    { "path": "/api/cron/sync", "schedule": "0 * * * *" },
    { "path": "/api/cron/alerts", "schedule": "*/30 * * * *" }
  ]
}
